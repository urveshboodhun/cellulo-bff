PORT=3001
NODE_ENV=development
AIRALO_BASE_URL=https://sandbox-partners-api.airalo.com/v2
AIRALO_CLIENT_ID=your_client_id
AIRALO_CLIENT_SECRET=your_client_secret
JWT_SECRET=your_jwt_secret
CORS_ORIGIN=https://your-frontend.example.com

# Optional: path to the SQLite database file (default: ./data/cellulo.db)
# DATABASE_PATH=./data/cellulo.db

# Optional: how often to refresh packages from Airalo in milliseconds (default: 6 hours)
# PACKAGE_SYNC_INTERVAL_MS=21600000
